---
// Fundations
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import BlogCard1 from "@/components/blog/BlogCard1.astro";
// Content
import { getCollection } from "astro:content";
const allPosts = await getCollection("posts");
allPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
});
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
---

<BaseLayout>
  <section class="bg-white overflow-hidden border-b border-base-200">
    <Wrapper variant="standardWide" class="px-8 py-16 lg:py-24">
      <div class="max-w-3xl">
        <Text
          tag="h1"
          variant="displayXL"
          class="tracking-tight text-base-900 text-balance"
        >
          Blog
        </Text>
        <Text tag="p" variant="textBase" class="font-medium text-base-600 mt-4">
          Guides, templates, and stories for internships, networking, and your
          first corporate role.
        </Text>
      </div>
    </Wrapper>
  </section>
  <section class="bg-base-100">
    <Wrapper variant="standard" class="py-16">
      <div class="flex flex-wrap gap-2 mb-12">
        {
          tags.map((tag, index) => (
            <>
              <a
                class="text-sm text-base-600 font-medium hover:text-base-900 capitalize"
                href={`/blog/tags/${tag}`}
              >
                {tag}
              </a>
              {index < tags.length - 1 && (
                <span class="text-base-300">·</span>
              )}
            </>
          ))
        }
      </div>
      <dl class="grid sm:grid-cols-2 lg:grid-cols-2 gap-x-12 gap-y-16">
        {allPosts.map((post) => <BlogCard1 post={post} />)}
      </dl>
    </Wrapper>
  </section>
</BaseLayout>
