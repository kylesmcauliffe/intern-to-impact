---
// Assets
import BrandLogo from "@/components/assets/BrandLogo.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const links = [
  { name: "Blog", link: "/blog" },
  { name: "Guides", link: "/blog/tags/guide" },
  { name: "About", link: "/about" },
  { name: "Contact", link: "/contact" },
];
---

<section class="bg-white overflow-hidden border-t border-base-200">
  <Wrapper variant="standard" class="py-16">
    <BrandLogo showIcon class="text-base-900 text-lg" />
    <Text tag="p" variant="textBase" class="mt-4 text-base-600 max-w-md">
      Career guides for young professionals — from intern to impact.
    </Text>
    <ul role="list" class="flex flex-wrap gap-x-6 gap-y-2 mt-10">
      {
        links.map((item) => (
          <li>
            <a
              class="text-base-600 hover:text-base-900 duration-200"
              href={item.link}
            >
              {item.name}
            </a>
          </li>
        ))
      }
    </ul>
  </Wrapper>
</section>
