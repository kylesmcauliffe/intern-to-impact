---
const { className = "", showIcon = false, ...rest } = Astro.props;
---

<span class:list={["inline-flex items-center gap-2 font-semibold tracking-tight", className]} {...rest}>
  {
    showIcon && (
      <img
        src="/icon.png"
        alt=""
        width="28"
        height="28"
        class="rounded-lg size-7"
      />
    )
  }
  <span>Intern</span>
  <span class="text-base-400" aria-hidden="true">→</span>
  <span>Impact</span>
</span>
