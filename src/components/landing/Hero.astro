---
// Assets
import { Image } from "astro:assets";
import One from "@/images/assets/1.png";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Marquee
export const tags = [
  "career strategy",
  "personal brand",
  "LinkedIn",
  "interview prep",
  "executive presence",
];
const repeated = Array(20).fill(tags.join(" — ")).join(" — ");
---

<section class="bg-accent-50 overflow-hidden relative">
  <Wrapper variant="standardWide" class="px-8 pb-0 py-12 lg:pt-24">
    <div class="grid items-end gap-4 lg:grid-cols-3 max-w-5xl mx-auto">
      <div class="lg:col-span-2">
        <Text
          tag="h1"
          variant="displayXL"
          class="tracking-tighter text-accent-800 text-balance"
        >
          From intern to impact
        </Text>
      </div>
      <Text tag="p" variant="textBase" class="font-medium text-accent-600">
        Demure, deliberate career strategy for women who want to show up polished
        — without performing.
      </Text>
    </div>
    <div class="relative mt-12">
      <Image
        width="1200"
        height="630"
        class="w-full max-h-[80vh] rounded-t-2xl relative object-cover object-top"
        src={One}
        alt="Intern to Impact"
      />
    </div>
    <div
      class="bg-accent-100 text-accent-700 font-medium relative rounded-b-2xl z-10 py-2 px-4 bottom-0 w-full overflow-x-hidden"
    >
      <div class="items-center relative animate-marquee flex whitespace-nowrap">
        {repeated}
      </div>
    </div>
  </Wrapper>
</section>
