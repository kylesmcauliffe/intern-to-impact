---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const tags = [
  "networking",
  "internships",
  "LinkedIn",
  "first-gen",
  "Bay Area",
  "career reps",
];
const repeated = Array(15).fill(tags.join(" · ")).join(" · ");
---

<section class="bg-white overflow-hidden border-b border-base-200">
  <Wrapper variant="standardWide" class="px-8 py-16 lg:py-24">
    <div class="grid items-end gap-6 lg:grid-cols-3 max-w-5xl mx-auto">
      <div class="lg:col-span-2">
        <Text
          tag="h1"
          variant="displayXL"
          class="tracking-tight text-base-900 text-balance"
        >
          From intern to impact
        </Text>
      </div>
      <Text tag="p" variant="textBase" class="font-medium text-base-600">
        Career guides for young professionals — especially if you're figuring it
        out without a family playbook.
      </Text>
    </div>
    <div class="flex flex-wrap gap-3 mt-10 max-w-5xl mx-auto">
      <Button isLink size="base" variant="default" href="#start-here">
        Start here
      </Button>
      <Button isLink size="base" variant="muted" href="/blog">
        Read the blog
      </Button>
    </div>
    <div
      class="bg-base-100 text-base-500 text-sm font-medium rounded-2xl mt-12 py-3 px-4 overflow-x-hidden"
    >
      <div class="animate-marquee flex whitespace-nowrap">{repeated}</div>
    </div>
  </Wrapper>
</section>
