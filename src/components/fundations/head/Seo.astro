---
import { AstroSeo } from "@lexingtonthemes/seo";
---

<AstroSeo
  title="Intern to Impact"
  description="Career coaching and personal branding for women going from intern to impact."
  canonical="https://yourdomain.com/"
  openGraph={{
    url: "https://yourdomain.com/",
    title: "Intern to Impact",
    description:
      "Career coaching and personal branding for women going from intern to impact.",
    images: [
      {
        url: "https://yourdomain.com/og-image.jpg",
        width: 1200,
        height: 630,
        alt: "Intern to Impact",
        type: "image/jpeg",
      },
    ],
    site_name: "Intern to Impact",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    handle: "@yourhandle",
    site: "@yourhandle",
    cardType: "summary_large_image",
  }}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://yourdomain.com/" />
<meta property="og:title" content="Intern to Impact" />
<meta
  property="og:description"
  content="Career coaching and personal branding for women going from intern to impact."
/>
<meta
  property="og:image"
  content="https://yourdomain.com/og-image.jpg"
/>

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="https://yourdomain.com/" />
<meta property="twitter:title" content="Intern to Impact" />
<meta
  property="twitter:description"
  content="Career coaching and personal branding for women going from intern to impact."
/>
<meta
  property="twitter:image"
  content="https://yourdomain.com/og-image.jpg"
/>

<!-- Canonical URL -->
<link rel="canonical" href="https://yourdomain.com/" />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
